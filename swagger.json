{
  "openapi": "3.0.3",
  "info": {
    "title": "Flora Backend API",
    "description": "REST API for Flora flower shop. Provides endpoints for managing bouquets, categories, and orders. Uses PostgreSQL database via Prisma ORM.",
    "version": "2.0.0",
    "contact": {
      "name": "Uzhvenko Denys"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/api/bouquets": {
      "get": {
        "tags": ["Bouquets"],
        "summary": "Get list of bouquets",
        "description": "Returns a list of bouquets with optional filtering, searching, sorting, and pagination.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search query (searches in title and description)",
            "required": false,
            "schema": {
              "type": "string",
              "maxLength": 100
            }
          },
          {
            "name": "favorite",
            "in": "query",
            "description": "Filter by favorite status",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "_sort",
            "in": "query",
            "description": "Sort field. Prefix with '-' for descending order.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["title", "-title", "createdAt", "-createdAt"]
            }
          },
          {
            "name": "_page",
            "in": "query",
            "description": "Page number for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "_per_page",
            "in": "query",
            "description": "Number of items per page",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 4
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Bouquet" }
                    },
                    { "$ref": "#/components/schemas/PaginatedBouquets" }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Bouquets"],
        "summary": "Create a new bouquet",
        "description": "Creates a new bouquet in the database.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateBouquetRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bouquet created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Bouquet" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/bouquets/{id}": {
      "get": {
        "tags": ["Bouquets"],
        "summary": "Get bouquet by ID",
        "description": "Returns a single bouquet by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Bouquet ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Bouquet" }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Bouquets"],
        "summary": "Update bouquet",
        "description": "Updates an existing bouquet by ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Bouquet ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateBouquetRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bouquet updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Bouquet" }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Bouquets"],
        "summary": "Delete bouquet",
        "description": "Deletes a bouquet by ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Bouquet ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bouquet deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Bouquet deleted successfully"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/bouquets/{bouquetId}/favorite": {
      "patch": {
        "tags": ["Bouquets"],
        "summary": "Update bouquet favorite status",
        "description": "Updates the favorite status of a bouquet.",
        "parameters": [
          {
            "name": "bouquetId",
            "in": "path",
            "description": "Bouquet ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateFavoriteRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Favorite status updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Bouquet" }
              }
            }
          },
          "404": {
            "description": "Bouquet not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "Get all categories",
        "description": "Returns a list of unique flower categories.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": ["top", "standart"]
                }
              }
            }
          }
        }
      }
    },
    "/api/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get all orders",
        "description": "Returns all created orders (stored in memory).",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Order" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Orders"],
        "summary": "Create a new order",
        "description": "Creates a new order with customer details.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateOrderRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Order created successfully"
                    },
                    "order": { "$ref": "#/components/schemas/Order" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Bouquet": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "photo": { "type": "string", "example": "./images/flowers/68498236a1003120786.png" },
          "title": { "type": "string", "example": "Midnight Garden" },
          "description": { "type": "string", "example": "A spellbinding bouquet..." },
          "favorite": { "type": "boolean", "example": false },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "PaginatedBouquets": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Bouquet" }
          },
          "first": { "type": "integer", "example": 1 },
          "prev": { "type": "integer", "nullable": true, "example": null },
          "next": { "type": "integer", "nullable": true, "example": 2 },
          "last": { "type": "integer", "example": 5 },
          "pages": { "type": "integer", "example": 5 },
          "items": { "type": "integer", "example": 20 }
        }
      },
      "CreateBouquetRequest": {
        "type": "object",
        "required": ["photo", "title", "description"],
        "properties": {
          "photo": { "type": "string", "example": "./images/flowers/photo.png" },
          "title": { "type": "string", "minLength": 2, "maxLength": 100, "example": "Beautiful Roses" },
          "description": { "type": "string", "minLength": 10, "maxLength": 1000, "example": "A stunning arrangement of red roses" },
          "favorite": { "type": "boolean", "default": false }
        }
      },
      "UpdateBouquetRequest": {
        "type": "object",
        "properties": {
          "photo": { "type": "string" },
          "title": { "type": "string", "minLength": 2, "maxLength": 100 },
          "description": { "type": "string", "minLength": 10, "maxLength": 1000 },
          "favorite": { "type": "boolean" }
        }
      },
      "UpdateFavoriteRequest": {
        "type": "object",
        "required": ["favorite"],
        "properties": {
          "favorite": { "type": "boolean", "example": true }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": ["name", "phone", "email"],
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 50, "example": "John Doe" },
          "phone": { "type": "string", "example": "+380991234567" },
          "email": { "type": "string", "format": "email", "example": "john@example.com" },
          "comment": { "type": "string", "maxLength": 500, "example": "Please deliver before 5pm" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "John Doe" },
          "phone": { "type": "string", "example": "+380991234567" },
          "email": { "type": "string", "example": "john@example.com" },
          "comment": { "type": "string", "example": "Please deliver before 5pm" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "Error description" }
        }
      }
    }
  }
}
